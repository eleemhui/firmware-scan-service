# Stage 1: build
FROM golang:1.22-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /firmware_scan_service ./cmd/api

# Stage 2: runtime
FROM alpine:3.19

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=builder /firmware_scan_service /app/firmware_scan_service
# Migrations are read from the filesystem at startup
COPY migrations/ /app/migrations/

EXPOSE 8080

ENTRYPOINT ["/app/firmware_scan_service"]
